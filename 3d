<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>High-Fidelity 3D Carousel</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    
    <style>
        /* --- 1. SETTING VARIABEL (TUNING ANIMASI DISINI) --- */
        :root {
            --bg-color: #f0f0f0;
            --ease-premium: cubic-bezier(0.19, 1, 0.22, 1); /* "The Nike/Apple Feel" */
            --anim-duration: 1.2s; /* Durasi panjang biar smooth */
            --perspective: 1200px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* --- 2. LAYOUT GRID --- */
        .viewport {
            width: 90%;
            max-width: 1400px;
            height: 80vh;
            display: grid;
            grid-template-columns: 1fr 1.2fr; /* Kiri Text, Kanan Visual */
            align-items: center;
            position: relative;
        }

        /* --- 3. BACKGROUND PARALLAX TEXT --- */
        .bg-watermark {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-size: 28vw; /* Super massive */
            font-weight: 800;
            color: rgba(0,0,0,0.04);
            line-height: 0.8;
            pointer-events: none;
            z-index: 0;
            white-space: nowrap;
            transition: all var(--anim-duration) var(--ease-premium);
        }

        /* --- 4. TEXT CONTENT (LEFT) --- */
        .content-stack {
            position: relative;
            z-index: 10;
            height: 300px; /* Area aman text */
            padding-left: 5vw;
        }

        .text-group {
            position: absolute;
            top: 0; left: 0;
            width: 100%;
            /* Default State: Hidden (Down) */
            opacity: 0;
            pointer-events: none;
            transform: translateY(40px);
            transition: all var(--anim-duration) var(--ease-premium);
        }

        .text-group.active {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }

        .label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: #888;
            margin-bottom: 20px;
            transition-delay: 0.1s; /* Stagger */
        }

        .headline {
            font-size: 5vw; /* Responsive font */
            font-weight: 800;
            line-height: 1.1;
            color: #111;
            margin-bottom: 30px;
            display: block;
            transition-delay: 0.2s; /* Stagger */
        }

        .cta-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            color: #111;
            border-bottom: 2px solid #111;
            padding-bottom: 5px;
            transition-delay: 0.3s; /* Stagger */
        }

        /* --- 5. 3D STAGE (RIGHT) - THE CORE --- */
        .stage-container {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            /* MAGIC SAUCE: Perspective */
            perspective: var(--perspective);
        }

        .logo-card-wrapper {
            position: absolute;
            width: 450px;
            height: 450px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            transform-style: preserve-3d; /* Wajib untuk 3D */
            
            /* State: HIDDEN (Waiting at Bottom) */
            opacity: 0;
            transform: translateY(100px) rotateX(-60deg) translateZ(-200px);
            transition: transform var(--anim-duration) var(--ease-premium), opacity var(--anim-duration) ease;
        }

        /* State: ACTIVE (Front & Center) */
        .logo-card-wrapper.active {
            opacity: 1;
            transform: translateY(0) rotateX(0deg) translateZ(0);
            z-index: 5;
        }

        /* State: EXITING (Flying Up & Away) */
        .logo-card-wrapper.exit-up {
            opacity: 0;
            transform: translateY(-100px) rotateX(60deg) translateZ(-200px);
            z-index: 1;
        }

        /* State: ENTERING (Coming from Bottom) */
        /* Kita pakai default state wrapper sbg entry state */

        /* Visual Kartu/Logo */
        .logo-visual {
            width: 100%;
            height: 100%;
            position: relative;
            z-index: 2;
            /* Floating Animation (Idle) */
            animation: float 6s ease-in-out infinite;
        }
        
        .logo-visual img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            filter: drop-shadow(0 20px 30px rgba(0,0,0,0.15));
        }

        /* Bayangan Lantai Dinamis */
        .floor-shadow {
            width: 250px;
            height: 20px;
            background: radial-gradient(closest-side, rgba(0,0,0,0.2), transparent);
            border-radius: 50%;
            margin-top: -40px;
            opacity: 0;
            transform: scale(0);
            transition: all var(--anim-duration) var(--ease-premium);
            filter: blur(8px);
        }

        .logo-card-wrapper.active .floor-shadow {
            opacity: 1;
            transform: scale(1);
        }

        /* --- 6. CONTROLS --- */
        .nav-controls {
            position: absolute;
            bottom: 50px;
            left: 55%; /* Align with right column roughly */
            display: flex;
            gap: 20px;
            z-index: 20;
        }

        .arrow-btn {
            width: 60px; height: 60px;
            border-radius: 50%;
            border: 1px solid #ccc;
            background: transparent;
            cursor: pointer;
            display: flex; justify-content: center; align-items: center;
            font-size: 20px;
            transition: all 0.3s;
        }
        .arrow-btn:hover { background: #111; color: #fff; border-color: #111; }

        /* Keyframes untuk Idle Floating */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }

    </style>
</head>
<body>

    <div class="viewport">
        <div class="bg-watermark" id="bg-text">TORCH</div>

        <div class="content-stack" id="text-stack">
            
            <div class="text-group active" data-index="0">
                <span class="label">01 — Internship Project</span>
                <h1 class="headline">Brand Strategy<br>For Torch.id</h1>
                <a href="#" class="cta-btn">View Case Study →</a>
            </div>

            <div class="text-group" data-index="1">
                <span class="label">02 — Creative Agency</span>
                <h1 class="headline">Visual Identity<br>For DIPDOP</h1>
                <a href="#" class="cta-btn">View Case Study →</a>
            </div>

            <div class="text-group" data-index="2">
                <span class="label">03 — Branding</span>
                <h1 class="headline">Social Media<br>For Tsukamie</h1>
                <a href="#" class="cta-btn">View Case Study →</a>
            </div>

        </div>

        <div class="stage-container" id="stage">
            
            <div class="logo-card-wrapper active" data-index="0">
                <div class="logo-visual">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/2/20/Adidas_Logo.svg" alt="Torch">
                </div>
                <div class="floor-shadow"></div>
            </div>

            <div class="logo-card-wrapper" data-index="1">
                <div class="logo-visual">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/a/a6/Logo_NIKE.svg" alt="Dipdop">
                </div>
                <div class="floor-shadow"></div>
            </div>

            <div class="logo-card-wrapper" data-index="2">
                <div class="logo-visual">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/4/44/Under_armour_logo.svg" alt="Tsukamie">
                </div>
                <div class="floor-shadow"></div>
            </div>

        </div>

        <div class="nav-controls">
            <button class="arrow-btn" onclick="prevSlide()">←</button>
            <button class="arrow-btn" onclick="nextSlide()">→</button>
        </div>
    </div>

    <script>
        // --- KONFIGURASI DATA ---
        const bgWords = ["TORCH", "DIPDOP", "RAMEN"];
        let currentIndex = 0;
        const totalSlides = 3;
        let isAnimating = false; // Mencegah spam klik

        // DOM Elements
        const slidesVisual = document.querySelectorAll('.logo-card-wrapper');
        const slidesText = document.querySelectorAll('.text-group');
        const bgText = document.getElementById('bg-text');

        function nextSlide() {
            if (isAnimating) return;
            isAnimating = true;

            let nextIndex = currentIndex + 1;
            if (nextIndex >= totalSlides) nextIndex = 0;

            updateSlider(nextIndex, 'next');
        }

        function prevSlide() {
            if (isAnimating) return;
            isAnimating = true;

            let prevIndex = currentIndex - 1;
            if (prevIndex < 0) prevIndex = totalSlides - 1;

            updateSlider(prevIndex, 'prev');
        }

        function updateSlider(newIndex, direction) {
            // 1. ANIMASI VISUAL (3D LOGO)
            const currentVisual = slidesVisual[currentIndex];
            const nextVisual = slidesVisual[newIndex];

            // Reset classes untuk slide baru agar siap masuk
            // Kita hapus class 'exit-up' kalau ada sisa dari putaran sebelumnya
            nextVisual.classList.remove('active', 'exit-up');
            
            // Force Reflow (PENTING: Agar browser sadar posisi start-nya di bawah)
            void nextVisual.offsetWidth;

            if (direction === 'next') {
                // Current: Keluar ke ATAS
                currentVisual.classList.remove('active');
                currentVisual.classList.add('exit-up');
                
                // Next: Masuk dari BAWAH (Default state CSS sudah di bawah)
                // Kita tinggal kasih class active biar dia naik ke tengah
                nextVisual.classList.add('active');
            } else {
                // LOGIKA MUNDUR (PREV) - Sedikit beda biar enak
                // Current: Turun ke BAWAH (Hilang class active)
                currentVisual.classList.remove('active');
                
                // Next: Harusnya turun dari ATAS. 
                // Karena setup CSS kita defaultnya dari bawah, ini butuh trik khusus
                // Tapi untuk simplifikasi prototype, kita pakai transisi Fade + Scale simple 
                // atau reset posisi instan. 
                // Untuk "Nike Feel", biasanya loop forward (Next terus) lebih optimal.
                
                // Kita reset posisi nextVisual dulu ke "Atas" secara instan
                nextVisual.style.transition = 'none';
                nextVisual.classList.add('exit-up'); 
                void nextVisual.offsetWidth; // Force paint
                nextVisual.style.transition = ''; // Balikin animasi
                
                // Sekarang animasikan masuk ke tengah
                setTimeout(() => {
                    nextVisual.classList.remove('exit-up');
                    nextVisual.classList.add('active');
                }, 10);
            }

            // 2. ANIMASI TEXT
            slidesText[currentIndex].classList.remove('active');
            slidesText[newIndex].classList.add('active');

            // 3. ANIMASI BACKGROUND PARALLAX
            // Geser teks sedikit saat transisi
            bgText.style.transform = "translate(-50%, -50%) translateX(-50px)";
            bgText.style.opacity = "0";

            setTimeout(() => {
                bgText.innerText = bgWords[newIndex];
                bgText.style.transform = "translate(-50%, -50%) translateX(0)";
                bgText.style.opacity = "1";
            }, 400); // Tunggu setengah jalan

            // Update Index
            currentIndex = newIndex;

            // Cooldown Animasi (Sesuai durasi CSS)
            setTimeout(() => {
                isAnimating = false;
                // Cleanup class sisa
                slidesVisual.forEach((slide, idx) => {
                    if(idx !== currentIndex) slide.classList.remove('active', 'exit-up');
                });
            }, 1200);
        }

    </script>
</body>
</html>