<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>TikTok Analyzer Card</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <style>
        :root{--card-w:320px}
        html,body{height:100%;margin:0}
        body{background:#f4f4f4;display:flex;align-items:center;justify-content:center;font-family:Inter,system-ui,Segoe UI,Roboto,'Helvetica Neue',Arial}
    /* phone-like frame */
    body{background:linear-gradient(180deg,#e9eefb,#f4f6fb);}
    .tiktok-shell{display:flex;align-items:center;justify-content:center;padding:40px}
    .tiktok-card{width:var(--card-w);background:#000;border-radius:36px;overflow:hidden;color:#fff;box-shadow:0 30px 50px rgba(2,6,23,.28);border:12px solid #111;transition:transform .22s,box-shadow .22s}
    .tiktok-card:hover{transform:translateY(-6px);box-shadow:0 36px 76px rgba(2,6,23,.32)}
        .video-wrapper{position:relative;height:500px;background:#111}
        .video-poster{display:flex;align-items:center;justify-content:center;position:relative;height:100%;background:linear-gradient(180deg,#161616,#0b0b0b);cursor:pointer}
        .video-poster:focus{outline:none;box-shadow:0 0 0 4px rgba(99,102,241,.12)}
        .play-svg{width:84px;height:84px;opacity:.96;transition:transform .18s}
        .video-poster:hover .play-svg{transform:scale(1.06)}
        .play-svg .bg{fill:rgba(255,255,255,.06)}
        .play-svg .tri{fill:#fff}
        .poster-text{position:absolute;left:14px;bottom:14px;font-size:12px;color:#bbb}
        .poster-hint{position:absolute;top:12px;left:50%;transform:translateX(-50%);font-size:13px;color:#ddd}
        .onboard{position:absolute;top:8px;left:8px;right:8px;margin:0 auto;text-align:center;font-size:12px;color:#eef;background:rgba(0,0,0,.24);padding:6px 8px;border-radius:10px;display:none}
        .onboard.show{display:block}

        .iframe-container{position:absolute;inset:0;background:#000}
        .iframe-toolbar{position:absolute;top:8px;right:8px;display:flex;gap:8px;z-index:40}
        .iframe-toolbar button{background:rgba(0,0,0,.6);color:#fff;border:0;padding:6px 8px;border-radius:8px;cursor:pointer;font-size:12px}

    /* navigation (prev/next) over video */
    .nav-btn{position:absolute;top:50%;transform:translateY(-50%);background:linear-gradient(90deg,rgba(0,0,0,.6),rgba(0,0,0,.35));border:0;color:#fff;padding:10px;border-radius:12px;cursor:pointer;font-size:18px;z-index:30;backdrop-filter:blur(4px);transition:transform .12s,opacity .18s}
    .nav-btn.left{left:8px}
    .nav-btn.right{right:8px}
    .nav-btn:active{transform:translateY(-50%) scale(.98)}
    .nav-btn:hover{transform:translateY(-50%) scale(1.03);opacity:0.98}
    .iframe-container, .video-poster{transition:transform .22s ease,opacity .22s ease}
    .video-title{position:absolute;left:16px;top:12px;color:#fff;background:rgba(0,0,0,.45);padding:6px 10px;border-radius:10px;font-size:13px;z-index:35;backdrop-filter:blur(4px)}
    .video-indicators{position:absolute;left:50%;transform:translateX(-50%);bottom:14px;display:flex;gap:8px;z-index:30}
    .video-indicators .dot{width:8px;height:8px;border-radius:99px;background:rgba(255,255,255,.22)}
    .video-indicators .dot.active{background:#fff}

    .result-box{position:absolute;left:16px;right:16px;bottom:84px;background:#fff;color:#111;padding:12px;border-radius:12px;text-align:center;transform:translateY(12px);opacity:0;pointer-events:none;transition:all .22s}
        .result-box.active{transform:translateY(0);opacity:1;pointer-events:auto}
    .er-value{font-size:34px;font-family:Space Grotesk,monospace;background:linear-gradient(90deg,#0f172a,#111827);-webkit-background-clip:text;background-clip:text;color:transparent;transition:transform .18s,opacity .18s}
    .er-value.pop{transform:scale(1.06);opacity:1}
    /* ER color themes (applied as classes) */
    .er-good{background:linear-gradient(90deg,#059669,#10b981)!important;-webkit-background-clip:text;background-clip:text;color:transparent}
    .er-medium{background:linear-gradient(90deg,#f59e0b,#f97316)!important;-webkit-background-clip:text;background-clip:text;color:transparent}
    .er-low{background:linear-gradient(90deg,#ef4444,#f43f5e)!important;-webkit-background-clip:text;background-clip:text;color:transparent}
        .result-box .meta{font-size:12px;color:#666;margin-top:6px}

        .stats-overlay{padding:16px;background:#000;border-top:1px solid #222}
        .metric-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px}
    .metric-item{background:#0e0e0e;padding:8px;border-radius:10px;text-align:center}
        .metric-val{font-family:Space Grotesk,monospace;font-weight:700;font-size:16px}
        .metric-label{display:block;margin-top:6px;opacity:.8;font-size:12px}
    .metric-input{background:transparent;border:0;color:#fff;font-family:Space Grotesk,monospace;font-weight:700;font-size:16px;text-align:center;width:100%;outline:none;transition:background .12s,color .12s}
    .metric-input:focus{background:rgba(255,255,255,0.03);border-radius:6px}
        .metric-input::-webkit-outer-spin-button,.metric-input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}

        .live-er{color:#ddd;text-align:center;margin-bottom:4px;font-size:13px}
        .actions{display:flex;justify-content:space-between;align-items:center;gap:8px}
    .small-link{background:transparent;border:1px solid #222;color:#ddd;padding:6px 8px;border-radius:8px;font-size:12px;transition:background .12s,border-color .12s,color .12s}
    .small-link:hover{background:#0b0b0b;border-color:#333;color:#fff}
    .live-er strong{display:inline-block;min-width:72px;text-align:center;transition:transform .18s}
    /* Modal for password lock */
    .pw-modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.55);display:flex;align-items:center;justify-content:center;z-index:200;opacity:0;pointer-events:none;transition:opacity .18s}
    .pw-modal-backdrop.show{opacity:1;pointer-events:auto}
    .pw-modal{background:#0f1724;color:#fff;padding:18px;border-radius:12px;min-width:320px;box-shadow:0 20px 60px rgba(2,6,23,.6)}
    .pw-modal h3{margin:0 0 8px;font-size:15px}
    .pw-modal label{display:block;font-size:13px;margin-top:8px;color:#cbd5e1}
    .pw-modal input[type=password]{width:100%;padding:8px;border-radius:8px;border:1px solid #23303a;background:#071018;color:#fff}
    .pw-modal .row{display:flex;gap:8px;margin-top:12px}
    .pw-modal .row button{flex:1;padding:8px;border-radius:8px;border:0;cursor:pointer}
    .pw-note{font-size:12px;color:#93c5fd;margin-top:8px}
    /* disabled input state for protected metrics */
    .metric-input[disabled]{opacity:.6;cursor:not-allowed}
    </style>
</head>
<body>

    <div class="tiktok-shell">
    <div class="tiktok-card" id="card-1">
    <div class="video-wrapper">
        <div class="video-poster" id="videoPoster" role="button" tabindex="0" aria-label="Open preview with audio">
            <svg class="play-svg" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                <circle class="bg" cx="32" cy="32" r="30"/>
                <path class="tri" d="M26 20L46 32L26 44V20Z"/>
            </svg>
            <div class="poster-text">Preview (Hidden link)</div>
            <div class="poster-hint">Click to open preview with audio</div>
            <div class="onboard" id="onboardHint">Tip: Click poster to open the Drive preview (audio supported).</div>
        </div>

        <div class="result-box" id="resultPopup" role="dialog" aria-hidden="true" aria-labelledby="erTitle">
            <div id="erTitle" style="font-size:12px;font-weight:700">ENGAGEMENT RATE</div>
            <div class="er-value" id="er-score">0.00%</div>
            <div class="meta">(Likes + Comments + Shares) / Views</div>
            <div class="meta" id="er-text" style="margin-top:6px;font-size:13px;color:#444">Calculating...</div>
            <button style="position:absolute;top:8px;right:8px;border:0;background:transparent;cursor:pointer" aria-label="Close" id="closeResult">✖</button>
        </div>
    <div class="video-title" id="videoTitle">Video 1</div>
        <!-- navigation buttons for multiple videos -->
        <button class="nav-btn left" id="prevBtn" aria-label="Previous">◀</button>
        <button class="nav-btn right" id="nextBtn" aria-label="Next">▶</button>
        <div class="video-indicators" id="videoIndicators"></div>
    </div>

    <div class="stats-overlay">
        <!-- DEFAULT METRICS: change the initial values below by editing the `value` attributes on the inputs.
             Example: <input id="inputViews" ... value="20000" /> will set default Views to 20,000.
             Note: values are persisted to localStorage after edits; clear localStorage to reset to these defaults. -->
        <div class="metric-grid">
            <div class="metric-item">
                <!-- Static metric displays. To change defaults, edit VIDEO_META in the script (see comments there). -->
                <div id="viewsVal" class="metric-val">15400</div>
                <span class="metric-label">Views</span>
            </div>
            <div class="metric-item">
                <div id="likesVal" class="metric-val">1200</div>
                <span class="metric-label">Likes</span>
            </div>
            <div class="metric-item">
                <div id="commentsVal" class="metric-val">45</div>
                <span class="metric-label">Comments</span>
            </div>
        </div>
        <div class="metric-grid" style="grid-template-columns:1fr 1fr;">
            <div class="metric-item">
                <div id="sharesVal" class="metric-val">20</div>
                <span class="metric-label">Shares</span>
            </div>
            <div style="display:flex;flex-direction:column;justify-content:center;align-items:center;">
                <div class="live-er">Live ER: <strong id="er-live">0.00%</strong></div>
                <div style="font-size:12px;color:#888;margin-top:6px">Metrics are set in code (VIDEO_META)</div>
            </div>
        </div>

        <div class="actions" style="margin-top:12px">
            <a id="originalLink" class="small-link" href="#" target="_blank" rel="noopener" title="Open source in new tab">Open Original</a>
        </div>
    </div>
    </div>
</div>

<!-- Password modal: used to set or verify edit password so only owner can edit metrics -->
<div id="pwModalBackdrop" class="pw-modal-backdrop" aria-hidden="true">
    <!-- Password modal removed in simplified version (metrics are now set in code). -->

<script>
// SINGLE CONFIG: change this to your Drive preview URL (the share preview link)
// Set to the Drive file preview for the video you want to embed.
const DRIVE_PREVIEW_URL = 'https://drive.google.com/file/d/1qYfrX_UofCuv6z1-5hD6LvUZS3XgGlcd/preview'; // Drive preview URL for the provided file

// Element refs (static displays)
const viewsVal = document.getElementById('viewsVal');
const likesVal = document.getElementById('likesVal');
const commentsVal = document.getElementById('commentsVal');
const sharesVal = document.getElementById('sharesVal');
const erLive = document.getElementById('er-live');
const resultBox = document.getElementById('resultPopup');
const scoreDisplay = document.getElementById('er-score');
const textDisplay = document.getElementById('er-text');
const closeResult = document.getElementById('closeResult');
const poster = document.getElementById('videoPoster');
const wrapper = document.querySelector('.video-wrapper');
const prevBtn = document.getElementById('prevBtn');
const nextBtn = document.getElementById('nextBtn');
const indicators = document.getElementById('videoIndicators');

// internal data model
// internal data model
// Programmatic defaults: you can set initial metric defaults here instead of (or in addition to)
// editing the HTML `value` attributes. These will be overridden by saved values from localStorage.
// Example: const data = { views: 20000, likes: 1500, comments: 60, shares: 30 };
const data = { views: 0, likes: 0, comments: 0, shares: 0 };

// --- Multi-video setup ---
// Provide an array of preview URLs (Drive preview or any embeddable preview). For now we create 3 identical videos as requested.
const VIDEO_SOURCES = [DRIVE_PREVIEW_URL, DRIVE_PREVIEW_URL, DRIVE_PREVIEW_URL];
let currentIndex = 0;

// Per-video default metrics (these are used when switching videos).
// EDIT METRICS HERE: change the numbers in VIDEO_META to set the default metrics
// for each video. Example:
//   VIDEO_META = [ { views: 10000, likes: 500, comments: 20, shares: 5 }, ... ]
const VIDEO_META = [
    { views: 15400, likes: 1200, comments: 45, shares: 20 },
    { views: 28400, likes: 3400, comments: 120, shares: 90 },
    { views: 9800, likes: 420, comments: 22, shares: 11 }
];

// Optional titles for each video (displayed on top-left)
const VIDEO_TITLES = [
    'Sample Video A',
    'Sample Video B',
    'Sample Video C'
];

function renderIndicators(){
    indicators.innerHTML = '';
    VIDEO_SOURCES.forEach((_, i) => {
        const d = document.createElement('div'); d.className = 'dot' + (i===currentIndex? ' active':'');
        indicators.appendChild(d);
    });
}

function updateTitle(){
    const t = document.getElementById('videoTitle');
    if (!t) return;
    const title = VIDEO_TITLES[currentIndex] || (`Video ${currentIndex+1}`);
    t.textContent = title;
}

// change iframe src with a smooth fade
function changeIframeSrcWithFade(newSrc){
    const container = wrapper.querySelector('.iframe-container');
    if (!container) return;
    // crossfade technique: create new iframe, fade it in, remove old iframe
    const oldIframe = container.querySelector('iframe');
    const newIframe = document.createElement('iframe');
    newIframe.src = newSrc; newIframe.style.width = '100%'; newIframe.style.height = '100%'; newIframe.style.border = '0';
    newIframe.style.position = 'absolute'; newIframe.style.left = '0'; newIframe.style.top = '0'; newIframe.style.opacity = '0'; newIframe.style.transition = 'opacity .28s ease';
    newIframe.setAttribute('allow', 'autoplay; encrypted-media');
    // disable nav during transition
    prevBtn.disabled = nextBtn.disabled = true;
    container.appendChild(newIframe);
    // once the new iframe loads (or after short timeout), fade
    const reveal = ()=>{
        requestAnimationFrame(()=>{ newIframe.style.opacity = '1'; if (oldIframe) oldIframe.style.opacity = '0'; });
        setTimeout(()=>{
            if (oldIframe && oldIframe.parentNode) oldIframe.parentNode.removeChild(oldIframe);
            // ensure new iframe occupies normal flow
            newIframe.style.position = ''; newIframe.style.opacity = ''; newIframe.style.transition = '';
            prevBtn.disabled = nextBtn.disabled = false;
        }, 320);
    };
    // try to reveal when loaded; fallback after 400ms
    newIframe.addEventListener('load', ()=> reveal());
    setTimeout(()=>{ if (container.contains(newIframe)) reveal(); }, 420);
}

function goToIndex(i){
    if (i < 0) i = VIDEO_SOURCES.length - 1;
    if (i >= VIDEO_SOURCES.length) i = 0;
    currentIndex = i;
    renderIndicators();
    // update inputs/metrics for the selected video (use saved per-index if present, otherwise VIDEO_META)
    loadMetricsForIndex(currentIndex);
    // update small original link to point to active source
    const originalLink = document.getElementById('originalLink');
    if (originalLink) originalLink.href = VIDEO_SOURCES[currentIndex];
    // if iframe is open, update src with fade
    const iframe = wrapper.querySelector('.iframe-container iframe');
    if (iframe) changeIframeSrcWithFade(VIDEO_SOURCES[currentIndex]);
    updateTitle();
}

// Helpers
function formatWithCommas(n){ return String(n).replace(/\B(?=(\d{3})+(?!\d))/g, ','); }
function unformat(s){ return Number(String(s).replace(/[^0-9\-]/g, '')) || 0; }

function syncDataFromInputs(){
    // Inputs were removed in the simplified UI. Read values from the static display elements instead.
    data.views = Math.max(0, unformat(viewsVal ? viewsVal.textContent : '0'));
    data.likes = Math.max(0, unformat(likesVal ? likesVal.textContent : '0'));
    data.comments = Math.max(0, unformat(commentsVal ? commentsVal.textContent : '0'));
    data.shares = Math.max(0, unformat(sharesVal ? sharesVal.textContent : '0'));
}

function computeER(){
    if (!data.views) return 0;
    const interactions = data.likes + data.comments + data.shares;
    return (interactions / data.views) * 100;
}

function updateLiveERDisplay(){
    const er = computeER();
    erLive.innerText = er.toFixed(2) + '%';
    scoreDisplay.innerText = er.toFixed(2) + '%';
    // verdict
    let verdict = 'Average Performance';
    if (er > 10) verdict = 'Viral Quality (Outstanding)';
    else if (er > 5) verdict = 'High Performance';
    else if (er > 3) verdict = 'Good Engagement';
    textDisplay.innerText = verdict;
    // color / theme the ER value and animate subtly
    // clear previous classes
    scoreDisplay.classList.remove('er-good','er-medium','er-low','pop');
    erLive.classList.remove('er-good','er-medium','er-low');
    if (er > 10) { scoreDisplay.classList.add('er-good','pop'); erLive.classList.add('er-good'); }
    else if (er > 5) { scoreDisplay.classList.add('er-medium','pop'); erLive.classList.add('er-medium'); }
    else { scoreDisplay.classList.add('er-low','pop'); erLive.classList.add('er-low'); }
    // remove pop after animation window so repeated updates still pop
    setTimeout(()=> scoreDisplay.classList.remove('pop'), 280);
}

// Persistence (debounced)
// Persist metrics per-video index. Stored as an array under key 'tiktok_metrics_by_index'.
function saveMetrics(){
    try{
        const raw = localStorage.getItem('tiktok_metrics_by_index');
        const arr = raw ? JSON.parse(raw) : [];
        arr[currentIndex] = { views: data.views, likes: data.likes, comments: data.comments, shares: data.shares };
        localStorage.setItem('tiktok_metrics_by_index', JSON.stringify(arr));
    }catch(e){}
}

function loadMetricsForIndex(idx){
    // Priority: saved per-index in localStorage -> VIDEO_META default -> HTML input defaults
    try{
        const raw = localStorage.getItem('tiktok_metrics_by_index');
        if (raw){
            const arr = JSON.parse(raw);
            if (arr && arr[idx]){
                const o = arr[idx];
                // update static displays
                if (viewsVal) viewsVal.textContent = String(o.views);
                if (likesVal) likesVal.textContent = String(o.likes);
                if (commentsVal) commentsVal.textContent = String(o.comments);
                if (sharesVal) sharesVal.textContent = String(o.shares);
                // sync data model and recalc ER
                data.views = Number(o.views) || 0;
                data.likes = Number(o.likes) || 0;
                data.comments = Number(o.comments) || 0;
                data.shares = Number(o.shares) || 0;
                updateLiveERDisplay();
                return;
            }
        }
        // fallback to VIDEO_META
        if (VIDEO_META[idx]){
            const m = VIDEO_META[idx];
            if (viewsVal) viewsVal.textContent = String(m.views);
            if (likesVal) likesVal.textContent = String(m.likes);
            if (commentsVal) commentsVal.textContent = String(m.comments);
            if (sharesVal) sharesVal.textContent = String(m.shares);
            data.views = Number(m.views) || 0;
            data.likes = Number(m.likes) || 0;
            data.comments = Number(m.comments) || 0;
            data.shares = Number(m.shares) || 0;
            updateLiveERDisplay();
            return;
        }
    }catch(e){}
    // final fallback: keep current inputs
    syncDataFromInputs(); updateLiveERDisplay();
}
let saveTimer = null;
function debounceSave(){ if (saveTimer) clearTimeout(saveTimer); saveTimer = setTimeout(saveMetrics, 600); }

// UI: create iframe on demand
function showDriveIframe(){
    if (!DRIVE_PREVIEW_URL) return window.open(DRIVE_PREVIEW_URL, '_blank');
    // prevent multiple
    if (wrapper.querySelector('.iframe-container')) return;
    const container = document.createElement('div');
    container.className = 'iframe-container';

    const toolbar = document.createElement('div');
    toolbar.className = 'iframe-toolbar';
    const openBtn = document.createElement('button'); openBtn.textContent = 'Open in new tab';
    openBtn.addEventListener('click', ()=> window.open(DRIVE_PREVIEW_URL, '_blank'));
    const closeBtn = document.createElement('button'); closeBtn.textContent = 'Close';
    closeBtn.addEventListener('click', ()=> {
        container.remove();
        poster.style.display = '';
        if (resultBox) resultBox.classList.remove('active');
    });
    toolbar.appendChild(openBtn); toolbar.appendChild(closeBtn);

    const iframe = document.createElement('iframe');
    iframe.src = DRIVE_PREVIEW_URL;
    iframe.style.width = '100%'; iframe.style.height = '100%'; iframe.style.border = '0';
    iframe.setAttribute('allow', 'autoplay; encrypted-media');

    container.appendChild(toolbar);
    container.appendChild(iframe);
    wrapper.appendChild(container);
    poster.style.display = 'none';
    // ensure iframe reflects current index
    iframe.src = VIDEO_SOURCES[currentIndex];
    updateTitle();
}

// Formatting handlers removed: inputs were removed in the simplified UI so
// there is no runtime need for number-format helpers.

// Performance popup opening was removed in the simplified UI. The result box
// remains in markup and can be controlled manually via the console if needed.

// Edit protection removed in simplified version (metrics live in code)

// Wire events once DOM ready
document.addEventListener('DOMContentLoaded', ()=>{
    // Inputs were removed in the simplified UI; no input formatting or initialization required.

    // initial sync: load metrics for starting index (updates displays and ER)
    loadMetricsForIndex(currentIndex);

    // Reset per-video button behavior
    const resetBtn = document.getElementById('resetBtn');
    if (resetBtn){
        resetBtn.addEventListener('click', ()=>{
            if (!confirm('Reset saved metrics for this video to defaults?')) return;
            try{
                const raw = localStorage.getItem('tiktok_metrics_by_index');
                const arr = raw ? JSON.parse(raw) : [];
                arr[currentIndex] = null;
                localStorage.setItem('tiktok_metrics_by_index', JSON.stringify(arr));
            }catch(e){}
            // reload defaults for this index
            loadMetricsForIndex(currentIndex);
        });
    }

    // poster click/keyboard
    if (poster){
        poster.addEventListener('click', showDriveIframe);
        poster.addEventListener('keydown', (e)=>{ if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); showDriveIframe(); } });
        const onboardSeen = localStorage.getItem('tiktok_onboard_seen');
        const onboard = document.getElementById('onboardHint');
        if (onboard && !onboardSeen){ onboard.classList.add('show'); setTimeout(()=>{ onboard.classList.remove('show'); localStorage.setItem('tiktok_onboard_seen','1'); }, 4800); }
    }

    // performance button removed in simplified UI (no-op)
    closeResult.addEventListener('click', ()=>{ resultBox.classList.remove('active'); resultBox.setAttribute('aria-hidden','true'); });

    // original link placeholder (user can change)
    const originalLink = document.getElementById('originalLink');
    if (originalLink) originalLink.href = VIDEO_SOURCES[currentIndex]; // set to active source
    // wire prev/next buttons
    prevBtn.addEventListener('click', ()=>{ goToIndex(currentIndex-1); });
    nextBtn.addEventListener('click', ()=>{ goToIndex(currentIndex+1); });

    // keyboard support (left/right), ignore when typing in an input
    document.addEventListener('keydown', (e)=>{
        const tag = (document.activeElement && document.activeElement.tagName) || '';
        if (tag === 'INPUT' || tag === 'TEXTAREA') return;
        if (e.key === 'ArrowLeft') { e.preventDefault(); goToIndex(currentIndex-1); }
        if (e.key === 'ArrowRight') { e.preventDefault(); goToIndex(currentIndex+1); }
    });

    // swipe handling for touch devices (smooth, interactive)
    let startX = null; let deltaX = 0; let swiping = false;
    wrapper.addEventListener('touchstart', (e)=>{
        if (!e.touches || e.touches.length !== 1) return;
        startX = e.touches[0].clientX; swiping = true; deltaX = 0;
    }, {passive:true});
    wrapper.addEventListener('touchmove', (e)=>{
        if (!swiping || !e.touches || e.touches.length !== 1) return;
        const x = e.touches[0].clientX; deltaX = x - startX;
        // visual feedback: translate poster or iframe container
        const cont = wrapper.querySelector('.iframe-container') || wrapper.querySelector('.video-poster');
        if (cont) cont.style.transform = `translateX(${deltaX}px)`;
    }, {passive:true});
    wrapper.addEventListener('touchend', (e)=>{
        if (!swiping) return; swiping = false;
        const threshold = 60; // px
        const cont = wrapper.querySelector('.iframe-container') || wrapper.querySelector('.video-poster');
        if (cont) cont.style.transform = '';
        if (deltaX > threshold) goToIndex(currentIndex-1);
        else if (deltaX < -threshold) goToIndex(currentIndex+1);
        startX = null; deltaX = 0;
    });
    // render indicators and title initially
    renderIndicators();
    updateTitle();
});

</script>

</body>
</html>