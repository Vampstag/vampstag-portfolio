<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Skill Equalizer</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        .equalizer-section {
            max-width: 700px; margin: 60px auto; 
            font-family: 'Inter', sans-serif;
            padding: 40px; background: #fff; color: #000;
        }

        .eq-header {
            display: flex; justify-content: space-between; align-items: flex-end;
            margin-bottom: 40px; padding-bottom: 20px;
            border-bottom: 2px solid #000;
        }

        h2 { text-transform: uppercase; font-weight: 800; font-size: 24px; letter-spacing: -1px; margin: 0; }
        
        .reset-btn {
            background: #000; color: #fff; border: none; padding: 10px 20px;
            font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;
            cursor: pointer; border-radius: 4px; transition: transform 0.1s;
        }
        .reset-btn:active { transform: scale(0.95); }

        /* --- FADERS CONTAINER --- */
        .faders-wrapper {
            display: flex; justify-content: space-between; gap: 20px; height: 300px;
        }

        .fader-group {
            display: flex; flex-direction: column; align-items: center; justify-content: flex-end;
            height: 100%; flex: 1;
        }

        /* --- VERTICAL SLIDER STYLING --- */
        /* Wrapper untuk memutar range input jadi vertikal */
        .range-wrapper {
            height: 200px; width: 40px; position: relative;
            display: flex; justify-content: center;
        }

        input[type=range][orient=vertical] {
            writing-mode: bt-lr; /* IE/Edge */
            -webkit-appearance: none;
            width: 8px; height: 100%;
            background: #e5e5e5;
            border-radius: 10px;
            outline: none;
            cursor: pointer;
        }

        /* Thumb (Kepala Fader) - Chrome/Safari */
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 40px; height: 20px;
            background: #000;
            border: 2px solid #fff;
            border-radius: 4px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.3);
            cursor: grab;
            margin-left: -16px; /* Center thumb on track (8px width) */
        }
        
        /* Trik untuk Firefox/Standard Vertical support */
        input[type=range] {
            appearance: slider-vertical; /* Standard modern browser */
            width: 8px;
        }

        .label-box {
            text-align: center; margin-top: 20px;
        }
        
        .skill-name { font-weight: 800; font-size: 12px; text-transform: uppercase; display: block; margin-bottom: 5px; }
        .skill-val { font-family: monospace; font-size: 11px; color: #666; }

    </style>
</head>
<body>

<div class="equalizer-section">
    <div class="eq-header">
        <div>
            <h2>The Skill Mix</h2>
            <span style="font-size: 12px; color: #666;">DRAG FADERS TO REMIX // CLICK BUTTON TO RESET</span>
        </div>
        <button class="reset-btn" onclick="setMyPreset()">Load My Preset</button>
    </div>

    <div class="faders-wrapper">
        
        <div class="fader-group">
            <div class="range-wrapper">
                <input type="range" class="fader" id="f1" min="0" max="100" value="50" oninput="updateVal('v1', this.value)">
            </div>
            <div class="label-box">
                <span class="skill-name">Strategy</span>
                <span class="skill-val" id="v1">50%</span>
            </div>
        </div>

        <div class="fader-group">
            <div class="range-wrapper">
                <input type="range" class="fader" id="f2" min="0" max="100" value="50" oninput="updateVal('v2', this.value)">
            </div>
            <div class="label-box">
                <span class="skill-name">Creative</span>
                <span class="skill-val" id="v2">50%</span>
            </div>
        </div>

        <div class="fader-group">
            <div class="range-wrapper">
                <input type="range" class="fader" id="f3" min="0" max="100" value="50" oninput="updateVal('v3', this.value)">
            </div>
            <div class="label-box">
                <span class="skill-name">Data</span>
                <span class="skill-val" id="v3">50%</span>
            </div>
        </div>

        <div class="fader-group">
            <div class="range-wrapper">
                <input type="range" class="fader" id="f4" min="0" max="100" value="50" oninput="updateVal('v4', this.value)">
            </div>
            <div class="label-box">
                <span class="skill-name">Copy</span>
                <span class="skill-val" id="v4">50%</span>
            </div>
        </div>

    </div>
</div>

<script>
    // Konfigurasi Skill Asli Kamu (Ubah Angkanya Disini)
    const myPreset = {
        f1: 90, // Strategy
        f2: 75, // Creative
        f3: 85, // Data
        f4: 60  // Copywriting
    };

    function updateVal(id, val) {
        document.getElementById(id).innerText = val + "%";
    }

    function setMyPreset() {
        // Loop ke setiap slider untuk animasi gerak
        const ids = ['f1', 'f2', 'f3', 'f4'];
        
        ids.forEach(id => {
            const el = document.getElementById(id);
            const target = myPreset[id];
            const current = parseInt(el.value);
            
            // Animasi simple dengan interval
            let step = current < target ? 1 : -1;
            
            const timer = setInterval(() => {
                const now = parseInt(el.value);
                
                // Cek apakah sudah sampai target
                if ((step > 0 && now >= target) || (step < 0 && now <= target)) {
                    clearInterval(timer);
                    el.value = target; // Pastikan pas
                } else {
                    el.value = now + step;
                }
                
                // Update teks angka di bawahnya
                // Cari ID teks: f1 -> v1
                const textId = id.replace('f', 'v');
                updateVal(textId, el.value);
                
            }, 5); // Kecepatan gerak (makin kecil makin cepat)
        });
    }

    // Jalankan preset otomatis saat loading (Opsional, biar keren pas dibuka)
    setTimeout(setMyPreset, 800);

</script>

</body>
</html>