<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vampstag Infinite Stack</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/Draggable.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <style>
        body {
            margin: 0;
            background-color: #f0f0f0; 
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        /* Space buat scroll biar kelihatan animasinya */
        .spacer { height: 100vh; display: flex; justify-content: center; align-items: center; color: #aaa; }

        /* Container Utama */
        .section-container {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            perspective: 1500px; /* Perspektif 3D lebih dalam */
            overflow: hidden;
        }

        /* Wrapper Kartu yang akan Miring/Tilt */
        .tilt-wrapper {
            position: relative;
            width: 320px;
            height: 480px;
            transform-style: preserve-3d; /* Wajib buat 3D */
            /* Awalnya opacity 0 & turun dikit buat animasi scroll */
            opacity: 0; 
            transform: translateY(100px);
        }

        .card {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            border-radius: 20px;
            
            /* --- DROP SHADOW YANG LEBIH BAGUS --- */
            /* Shadow berlapis biar kerasa tebal dan misah */
            box-shadow: 
                0 5px 10px rgba(0,0,0,0.05),
                0 15px 40px rgba(0,0,0,0.2);
            
            cursor: grab;
            background-size: cover;
            background-position: center;
            background-color: #fff;
            
            /* Border tipis biar makin tegas misahnya (Optional) */
            border: 1px solid rgba(0,0,0,0.05);

            will-change: transform; 
            transform-origin: center center;
        }

        .card:active { cursor: grabbing; }

        /* Label nomor (Opsional, buat debug urutan) */
        .debug-num {
            position: absolute; top: 10px; left: 10px;
            background: rgba(0,0,0,0.5); color: #fff;
            padding: 5px 10px; border-radius: 5px; font-size: 12px;
            pointer-events: none; display: none; /* Ubah ke block kalau mau liat nomor */
        }
    </style>
</head>
<body>

    <div class="spacer">SCROLL DOWN ↓</div>

    <div class="section-container">
        <div class="tilt-wrapper" id="stack-wrapper">
            </div>
    </div>

    <div class="spacer">SCROLL UP ↑</div>

    <script>
        gsap.registerPlugin(Draggable, ScrollTrigger);

        // --- 1. CONFIGURATION ---
        // Masukkan 10 Gambar kamu di sini
        const IMAGE_URLS = [
            'https://cdn.prod.website-files.com/6933c25a0996b0f96f5c2bc3/69392166df131d7c32695d7b_dimas%201%20ags0023.jpg', // 1 (Sepatu Merah)
            'https://images.unsplash.com/photo-1600185365926-3a2ce3cdb9eb?q=80&w=1000&auto=format&fit=crop', // 2 (Sepatu Orange)
            'https://images.unsplash.com/photo-1549298916-b41d501d3772?q=80&w=1000&auto=format&fit=crop', // 3 (Sepatu Boots)
            'https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?q=80&w=1000&auto=format&fit=crop', // 4
            'https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?q=80&w=1000&auto=format&fit=crop', // 5
            'https://images.unsplash.com/photo-1608231387042-66d1773070a5?q=80&w=1000&auto=format&fit=crop', // 6
            'https://images.unsplash.com/photo-1560769629-975e13f0c470?q=80&w=1000&auto=format&fit=crop', // 7
            'https://plus.unsplash.com/premium_photo-1663100722417-6e36673fe071?q=80&w=1000&auto=format&fit=crop', // 8
            'https://images.unsplash.com/photo-1512374382149-233c42b6a83b?q=80&w=1000&auto=format&fit=crop', // 9
            'https://images.unsplash.com/photo-1525966222134-fcfa99b8ae77?q=80&w=1000&auto=format&fit=crop'  // 10
        ];

        const VISIBLE_CARDS = 5; // Berapa kartu yang kelihatan numpuk
        const CONTAINER = document.getElementById('stack-wrapper');
        
        // State Global
        let cardElements = []; 
        let currentImgIndex = 0; // Pointer untuk urutan gambar (0 - 9)

        // --- 2. INIT FUNCTION ---
        function init() {
            // A. Buat Kartu Awal (Sebanyak VISIBLE_CARDS)
            // Kita loop mundur biar index 0 ada di paling bawah tumpukan DOM
            for (let i = 0; i < VISIBLE_CARDS; i++) {
                // Ambil gambar berdasarkan index
                let img = IMAGE_URLS[i % IMAGE_URLS.length];
                createCard(img, true); // true = mode init
                currentImgIndex++;
            }
            
            // B. Atur Posisi Visual Stack
            updateStackVisuals(0); // 0 duration = instant

            // C. Setup Mouse Follow (Tilt Effect)
            setupMouseTilt();

            // D. Setup Scroll Entrance
            setupScrollEntrance();
        }

        // --- 3. CREATE CARD LOGIC ---
        function createCard(imgUrl, isInit = false) {
            const card = document.createElement('div');
            card.classList.add('card');
            card.style.backgroundImage = `url('${imgUrl}')`;
            
            // Debug Number (Optional)
            // card.innerHTML = `<span class="debug-num">${currentImgIndex}</span>`;

            // Insert ke PALING BELAKANG (Prepend) di DOM
            CONTAINER.insertBefore(card, CONTAINER.firstChild);
            
            // Masukkan ke Array state (Index 0 = Paling Belakang, Index Terakhir = Paling Depan)
            cardElements.push(card);

            // Jika bukan init (artinya restack), set kondisi awal biar smooth animasi masuknya
            if (!isInit) {
                gsap.set(card, { 
                    opacity: 0, 
                    scale: 0.8, 
                    y: -50 // Muncul dari atas sedikit
                });
            }

            // Aktifkan Drag HANYA untuk kartu paling depan (Array terakhir)
            refreshDraggable();
        }

        // --- 4. REFRESH DRAGGABLE ---
        // Fungsi ini memastikan hanya kartu paling atas yang bisa didrag
        function refreshDraggable() {
                // Matikan semua drag dulu (tangani baik instance maupun array)
                cardElements.forEach(el => {
                    if (el._gsapDrag) {
                        if (Array.isArray(el._gsapDrag)) {
                            el._gsapDrag.forEach(inst => inst && inst.disable && inst.disable());
                        } else if (el._gsapDrag.disable) {
                            el._gsapDrag.disable();
                        }
                        el._gsapDrag = null;
                    }
                });

                // Ambil kartu paling atas (index terakhir di array)
                const topCard = cardElements[cardElements.length - 1];
                if (!topCard) return; // safety
            
                // Bikin Draggable baru buat si topCard (simpan array yang dikembalikan)
                const dragInstances = Draggable.create(topCard, {
                type: "x,y",
                edgeResistance: 0.65,
                bounds: window,
                inertia: true,
                onDrag: function() {
                    // Miring dikit pas didrag
                    gsap.to(this.target, { rotation: this.x * 0.05, duration: 0.1 });
                },
                onRelease: function() {
                    const threshold = 100;
                    if (Math.abs(this.x) > threshold || Math.abs(this.y) > threshold) {
                        throwCard(this.target, this.x, this.y);
                    } else {
                        // Snap Back
                        gsap.to(this.target, {
                            x: 0, y: 0, rotation: 0,
                            duration: 0.5, ease: "elastic.out(1, 0.5)"
                        });
                    }
                }
            });
                // Simpan referensi drag di elemennya biar bisa didisable nanti
                topCard._gsapDrag = dragInstances;
        }

        // --- 5. VISUAL STACK LOGIC (YANG BIKIN EFEK TUMPUK) ---
        function updateStackVisuals(duration = 0.5) {
            cardElements.forEach((card, i) => {
                // i = 0 adalah kartu paling belakang
                // i = length-1 adalah kartu paling depan
                
                // Kita mau hitung jarak dari DEPAN. 
                // index 0 (Depan) -> index 1 (Belakangnya) -> dst
                const reverseIndex = (cardElements.length - 1) - i; 

                gsap.to(card, {
                    scale: 1 - (reverseIndex * 0.05), // Kecilin 5% tiap langkah ke belakang
                    y: reverseIndex * 15, // Turun 15px tiap langkah
                    zIndex: i, // Z-index ngikutin array (makin akhir makin atas)
                    opacity: 1, // Pastikan visible
                    duration: duration,
                    ease: "power3.out", // Smooth easing
                    boxShadow: "0 5px 10px rgba(0,0,0,0.05), 0 15px 40px rgba(0,0,0,0.2)" // Reset shadow
                });
            });
        }

        // --- 6. THROW & LOOP LOGIC ---
        function throwCard(card, velX, velY) {
            // Disable drag
            if (card._gsapDrag) {
                if (Array.isArray(card._gsapDrag)) {
                    card._gsapDrag.forEach(inst => inst && inst.disable && inst.disable());
                } else if (card._gsapDrag.disable) {
                    card._gsapDrag.disable();
                }
                card._gsapDrag = null;
            }

            // Animasi Lempar
            gsap.to(card, {
                x: velX * 5,
                y: velY * 5 + 500, // Gravity effect
                rotation: velX * 0.2,
                opacity: 0,
                duration: 0.5,
                ease: "power1.in",
                onComplete: () => {
                    // 1. Hapus kartu lama dari DOM & Array
                    card.remove();
                    cardElements = cardElements.filter(el => el !== card);
                    
                    // 2. Tentukan gambar berikutnya (Looping)
                    // Ambil gambar dari array URL menggunakan pointer global
                    const nextImg = IMAGE_URLS[currentImgIndex % IMAGE_URLS.length];
                    currentImgIndex++; // Geser pointer ke gambar selanjutnya

                    // 3. Buat kartu baru di paling belakang
                    createCard(nextImg);

                    // 4. Update posisi visual (Kartu baru masuk, kartu lain maju)
                    updateStackVisuals(0.6); // 0.6s animation

                    // 5. Refresh logic drag (pindah ke kartu yg sekarang di depan)
                    refreshDraggable();
                }
            });
        }

        // --- 7. MOUSE FOLLOW / TILT EFFECT ---
        function setupMouseTilt() {
            window.addEventListener('mousemove', (e) => {
                // Hitung posisi mouse relatif ke tengah layar (-1 sampai 1)
                const xPct = (e.clientX / window.innerWidth) - 0.5;
                const yPct = (e.clientY / window.innerHeight) - 0.5;

                // Gerakkan Container Wrapper
                gsap.to('.tilt-wrapper', {
                    rotationY: xPct * 20, // Max miring 20 derajat horizontal
                    rotationX: -yPct * 20, // Max miring 20 derajat vertikal (minus biar natural)
                    duration: 1, // Durasi agak lama biar efeknya 'floating' dan smooth
                    ease: "power2.out"
                });
            });
        }

        // --- 8. SCROLL ENTRANCE ANIMATION ---
        function setupScrollEntrance() {
            gsap.to('.tilt-wrapper', {
                scrollTrigger: {
                    trigger: ".section-container",
                    start: "top 70%", // Mulai animasi pas elemen masuk 70% viewport
                    toggleActions: "play none none reverse" // Play pas masuk, Reverse pas keluar
                },
                opacity: 1,
                y: 0, // Naik ke posisi normal (dari translateY 100px di CSS)
                duration: 1.2,
                ease: "expo.out" // Easing sangat smooth (Cepat di awal, lambat di akhir)
            });
        }

        // JALANKAN
        init();

    </script>
</body>
</html>